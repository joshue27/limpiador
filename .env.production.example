# Limpiador WhatsApp Cloud — Producción
# Copiar a .env y ajustar valores reales

NODE_ENV=production
APP_URL=https://tu-dominio.com

# PostgreSQL / Prisma
DATABASE_URL=postgresql://limpiador:CONTRASENA_SEGURA@postgres:5432/limpiador?schema=public

# Redis / BullMQ
REDIS_URL=redis://redis:6379

# Sessions y auth (generar con: openssl rand -base64 32)
SESSION_SECRET=GENERAR-CON-OPENSSL-RAND-BASE64-32
SESSION_COOKIE_NAME=limpiador_session
SESSION_TTL_SECONDS=604800

# Rate limits (producción: más permisivos para login)
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_MAX=10
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_MAX=120

# WhatsApp Cloud API
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=TU-PHONE-ID
WHATSAPP_BUSINESS_ACCOUNT_ID=TU-BUSINESS-ID
WHATSAPP_ACCESS_TOKEN=TU-TOKEN
WHATSAPP_APP_SECRET=TU-APP-SECRET
WHATSAPP_WEBHOOK_VERIFY_TOKEN=TU-VERIFY-TOKEN
# Required for encrypting/decrypting config/whatsapp.json secrets (generate with: openssl rand -hex 32)
WHATSAPP_SETTINGS_KEY=GENERAR-CON-OPENSSL-RAND-HEX-32

# Almacenamiento privado
PRIVATE_MEDIA_ROOT=./media
PRIVATE_EXPORT_ROOT=./exports
PRIVATE_BACKUP_ROOT=/var/backups/limpiador/postgres
MEDIA_MAX_BYTES=26214400

# Modo producción: NO ignorar ventana de 24h
WHATSAPP_WINDOW_BYPASS=false

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tu-dominio.com
