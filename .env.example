# Copy to .env on the VPS or local dev machine. Never commit real values.
#
# Docker Compose: use service hostnames `postgres` and `redis`:
#   DATABASE_URL=postgresql://limpiador:change-me@postgres:5432/limpiador?schema=public
#   REDIS_URL=redis://redis:6379
# Running Node/Prisma directly on your host while DB/Redis are published by Docker:
#   DATABASE_URL=postgresql://limpiador:change-me@localhost:5432/limpiador?schema=public
#   REDIS_URL=redis://localhost:6379
NODE_ENV=development
APP_URL=http://localhost:3000

# PostgreSQL / Prisma
DATABASE_URL=postgresql://limpiador:change-me@localhost:5432/limpiador?schema=public
TEST_DATABASE_URL=postgresql://limpiador:change-me@localhost:5433/limpiador_test?schema=public

# Redis / BullMQ
REDIS_URL=redis://localhost:6379
TEST_REDIS_URL=redis://localhost:6380

# Sessions and auth. Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-at-least-32-characters
SESSION_COOKIE_NAME=limpiador_session
SESSION_TTL_SECONDS=604800

# Rate limits
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_MAX=5
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_MAX=120

# WhatsApp Cloud API - server-side only, never expose with NEXT_PUBLIC_
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=replace-me
WHATSAPP_BUSINESS_ACCOUNT_ID=replace-me
WHATSAPP_ACCESS_TOKEN=replace-me
WHATSAPP_APP_SECRET=replace-me
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-me
# Required for encrypting/decrypting config/whatsapp.json secrets. Generate with: openssl rand -hex 32
WHATSAPP_SETTINGS_KEY=replace-with-64-hex-chars

# Private local storage roots mounted as persistent VPS volumes
PRIVATE_MEDIA_ROOT=./media
PRIVATE_EXPORT_ROOT=./exports
MEDIA_MAX_BYTES=26214400

# Email / SMTP (Gmail requiere contraseña de aplicación)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-password-de-aplicacion
SMTP_FROM=noreply@limpiador.app
